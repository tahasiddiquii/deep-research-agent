# deep-research-agent runs fully offline by default — no keys required.

# Synthesis provider: "extractive" (default, deterministic), "openai", or "anthropic".
RESEARCH_PROVIDER=extractive
RESEARCH_MODEL=extractive-small

# Hard budget — the manager stops when either ceiling is hit.
RESEARCH_MAX_STEPS=24
RESEARCH_MAX_SEARCHES=6
RESEARCH_TOP_K=3

# Optional: real model synthesis (only if RESEARCH_PROVIDER is set above).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
